---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import adpasssyncLogo from '../assets/adpasssync-logo.png';
---

<BaseLayout
  title="Products — AD Argus"
  description="AD Argus products, including ADPassSync for real-time Active Directory password synchronization."
>
  <section class="page-head">
    <div class="container">
      <span class="eyebrow">Products</span>
      <h1 class="section-title">Software we build</h1>
      <p class="lead">
        AD Argus builds focused, dependable cybersecurity software. Every product
        is engineered around the same principles: security by design, operational
        simplicity, and respect for the teams who run it.
      </p>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="container">
      <article class="product-card">
        <div class="product-main">
          <span class="badge">Flagship</span>
          <h2 class="product-title">ADPassSync</h2>
          <p class="lead">
            Real-time Active Directory password synchronization. ADPassSync
            captures password changes as they happen and keeps credentials
            consistent across your directories and connected systems — giving
            users a single password while keeping administrators in control.
          </p>
          <ul class="feature-list">
            <li>Event-driven, real-time synchronization</li>
            <li>Hybrid and multi-domain environments</li>
            <li>Secure handling of credential data</li>
            <li>Designed for IT and security operations</li>
          </ul>
          <div class="product-actions">
            <a href="https://adpasssync.com" rel="noopener" class="btn btn-primary">
              Visit adpasssync.com ↗
            </a>
            <a href="/contact" class="btn btn-ghost">Talk to us</a>
          </div>
        </div>
        <aside class="product-aside">
          <div class="aside-logo">
            <Image
              src={adpasssyncLogo}
              alt="ADPassSync logo"
              widths={[240, 360, 480]}
              sizes="(max-width: 860px) 200px, 240px"
              class="logo-img"
            />
            <p class="aside-caption">Always protecting your credentials.</p>
          </div>
        </aside>
      </article>

      <div class="more-soon card">
        <h3>More on the way</h3>
        <p class="text-muted">
          We're a focused team expanding our portfolio deliberately. If there's a
          directory-security problem you wish someone would solve well,
          <a href="/contact">tell us about it</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-bottom: 2rem;
  }
  .product-card {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: 2.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    align-items: center;
  }
  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--border-bright);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    margin-bottom: 1rem;
  }
  .product-title {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin-bottom: 1rem;
  }
  .feature-list {
    list-style: none;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 0.7rem;
  }
  .feature-list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--text-muted);
  }
  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
  }
  .product-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .aside-logo {
    text-align: center;
  }
  .logo-img {
    width: 100%;
    max-width: 240px;
    height: auto;
    margin-inline: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border-bright);
    box-shadow: 0 18px 50px -20px rgba(0, 0, 0, 0.7);
  }
  .aside-caption {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 1rem;
  }
  .more-soon {
    margin-top: 1.5rem;
  }
  .more-soon h3 {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 860px) {
    .product-card {
      grid-template-columns: 1fr;
      padding: 1.75rem;
    }
    .product-aside {
      order: -1;
    }
    .logo-img {
      max-width: 160px;
    }
  }
</style>
