---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = 'June 22, 2026';
---

<BaseLayout title="Terms of Use — AD Argus" description="Terms governing use of the AD Argus website.">
  <section class="page-head">
    <div class="container narrow">
      <span class="eyebrow">Legal</span>
      <h1 class="section-title">Terms of Use</h1>
      <p class="text-muted">Last updated: {updated}</p>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="container narrow legal">
      <div class="notice">
        <strong>Template notice.</strong> These terms are a starting point and
        should be reviewed by legal counsel before you rely on them. Product
        licensing is governed by separate agreements.
      </div>

      <h2>1. Acceptance</h2>
      <p>
        By accessing adargus.com you agree to these Terms of Use. If you do not
        agree, please do not use the site.
      </p>

      <h2>2. Use of the site</h2>
      <p>
        You may use this site for lawful, informational purposes. You agree not
        to interfere with its operation or security, or to access it in any way
        that violates applicable law.
      </p>

      <h2>3. Intellectual property</h2>
      <p>
        The content, branding, and software referenced on this site are owned by
        AD Argus Cybersecurity Corporation or its licensors and are protected by
        applicable laws. "AD Argus" and "ADPassSync" are marks of AD Argus
        Cybersecurity Corporation.
      </p>

      <h2>4. No warranty</h2>
      <p>
        This website is provided "as is" without warranties of any kind. Use of
        our software products is governed by their own licence and support terms.
      </p>

      <h2>5. Limitation of liability</h2>
      <p>
        To the maximum extent permitted by law, AD Argus is not liable for any
        indirect or consequential damages arising from use of this website.
      </p>

      <h2>6. Governing law</h2>
      <p>
        These terms are governed by the laws of Canada and the applicable
        province in which AD Argus Cybersecurity Corporation is registered.
      </p>

      <h2>7. Contact</h2>
      <p>
        Questions about these terms? Email
        <a href="mailto:legal@adargus.com">legal@adargus.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow {
    max-width: 760px;
  }
  .page-head {
    padding-bottom: 1rem;
  }
  .legal h2 {
    font-size: 1.3rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .legal p {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .notice {
    background: rgba(248, 113, 113, 0.08);
    border: 1px solid rgba(248, 113, 113, 0.35);
    border-radius: var(--radius-sm);
    padding: 1rem 1.25rem;
    color: var(--text);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }
</style>
