---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CveTicker from '../../components/CveTicker.astro';

const reports = (await getCollection('knowledge', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const catLabel: Record<string, string> = {
  'zero-day': '0-Day',
  breach: 'Breach',
  advisory: 'Advisory',
};

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' });

const host = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
};
---

<BaseLayout
  title="Knowledge Center — AD Argus"
  description="Identity-focused exploit and breach intelligence — new zero-days, exposed credential dumps, and directory-security advisories, summarized from primary sources."
>
  <section class="page-head">
    <div class="container">
      <span class="eyebrow">Knowledge Center</span>
      <h1 class="section-title">Identity threat intelligence</h1>
      <p class="lead">
        A running digest of identity-related exploit and breach news — new
        zero-days, exposed credential dumps, and directory-security advisories —
        each summarized in our own words with a link to the primary source.
      </p>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="container kc-layout">
      <div class="kc-main">
        {
          reports.length === 0 ? (
            <p class="text-muted">No reports yet — check back soon.</p>
          ) : (
            <ol class="kc-list">
              {reports.map((r) => (
                <li>
                  <article class="kc-card">
                    <div class="kc-meta">
                      <span class={`kc-cat kc-cat-${r.data.category}`}>
                        {catLabel[r.data.category]}
                      </span>
                      <time datetime={r.data.date.toISOString()}>
                        {fmtDate(r.data.date)}
                      </time>
                    </div>
                    <h2 class="kc-card-title">
                      <a href={`/knowledge-center/${r.id}/`}>{r.data.title}</a>
                    </h2>
                    <p class="kc-summary">{r.data.summary}</p>
                    <div class="kc-card-foot">
                      <a href={`/knowledge-center/${r.id}/`} class="kc-read">
                        Read summary →
                      </a>
                      <span class="kc-source">Source: {r.data.sourceName}</span>
                    </div>
                  </article>
                </li>
              ))}
            </ol>
          )
        }
      </div>

      <div class="kc-side">
        <CveTicker />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-bottom: 1.5rem;
  }
  .kc-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2.5rem;
    align-items: start;
  }
  .kc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
  .kc-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1.6rem;
    transition: border-color 0.2s ease;
  }
  .kc-card:hover {
    border-color: var(--border-bright);
  }
  .kc-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .kc-cat {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border-bright);
  }
  .kc-cat-zero-day {
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.4);
    background: rgba(248, 113, 113, 0.08);
  }
  .kc-cat-breach {
    color: #fb923c;
    border-color: rgba(251, 146, 60, 0.4);
    background: rgba(251, 146, 60, 0.08);
  }
  .kc-cat-advisory {
    color: var(--accent);
    border-color: var(--border-bright);
    background: rgba(45, 212, 191, 0.06);
  }
  .kc-card-title {
    font-size: 1.2rem;
    line-height: 1.3;
    margin-bottom: 0.6rem;
  }
  .kc-card-title a {
    color: var(--text);
  }
  .kc-card-title a:hover {
    color: var(--accent-bright);
  }
  .kc-summary {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.1rem;
  }
  .kc-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .kc-read {
    font-weight: 600;
    font-size: 0.9rem;
  }
  .kc-source {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .kc-layout {
      grid-template-columns: 1fr;
    }
    .kc-side {
      order: -1;
    }
  }
</style>
