---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — AD Argus">
  <section class="notfound">
    <div class="container">
      <span class="eyebrow">404</span>
      <h1 class="section-title">This page slipped past our watch</h1>
      <p class="lead" style="margin-inline:auto;">
        The page you're looking for doesn't exist or has moved.
      </p>
      <a href="/" class="btn btn-primary" style="margin-top:1.75rem;">
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding-block: clamp(5rem, 14vw, 9rem);
  }
</style>
