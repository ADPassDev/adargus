---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AD Argus — Vigilant Cybersecurity Software',
  description = 'AD Argus builds vigilant cybersecurity software for the modern enterprise, including ADPassSync for Active Directory password synchronization.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://adargus.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:site_name" content="AD Argus" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#0a0e14" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--accent);
        color: #04201c;
        padding: 0.5rem 1rem;
        z-index: 100;
        border-radius: 0 0 var(--radius-sm) 0;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
