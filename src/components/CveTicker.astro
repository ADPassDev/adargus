---
import cveData from '../data/cves.json';

const { items = [], updated } = cveData as {
  updated: string | null;
  items: Array<{
    id: string;
    title: string;
    vendor?: string;
    severity: string;
    score: number | null;
    kev: boolean;
    date: string;
    url: string;
  }>;
};

const updatedLabel = updated
  ? new Date(updated).toLocaleDateString('en-CA', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : null;

const sevClass = (s: string) => {
  const k = s.toUpperCase();
  if (k === 'EXPLOITED') return 'sev-exploited';
  if (k === 'CRITICAL') return 'sev-critical';
  if (k === 'HIGH') return 'sev-high';
  if (k === 'MEDIUM') return 'sev-medium';
  if (k === 'LOW') return 'sev-low';
  return 'sev-unrated';
};

const sevLabel = (item: { severity: string; score: number | null }) => {
  const k = item.severity.toUpperCase();
  if (k === 'EXPLOITED') return 'Exploited';
  if (k === 'UNRATED') return 'Unrated';
  return item.score != null ? `${k} ${item.score}` : k;
};
---

<aside class="ticker" aria-label="Latest identity-related CVEs">
  <div class="ticker-head">
    <span class="ticker-eyebrow">CVE Watch</span>
    <h2 class="ticker-title">Identity vulnerabilities</h2>
    {updatedLabel && <p class="ticker-updated">Updated {updatedLabel}</p>}
  </div>

  {
    items.length === 0 ? (
      <p class="ticker-empty">No current entries.</p>
    ) : (
      <ol class="ticker-list">
        {items.map((c) => (
          <li class="ticker-item">
            <a href={c.url} rel="noopener" class="ticker-link">
              <div class="ticker-row">
                <span class={`sev ${sevClass(c.severity)}`}>{sevLabel(c)}</span>
                <span class="ticker-id">{c.id}</span>
              </div>
              <p class="ticker-desc">{c.title}</p>
            </a>
          </li>
        ))}
      </ol>
    )
  }

  <p class="ticker-source">
    Sources: <a href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog" rel="noopener">CISA KEV</a>
    &amp; <a href="https://nvd.nist.gov/" rel="noopener">NVD</a>
  </p>
</aside>

<style>
  .ticker {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.4rem 1.1rem;
    position: sticky;
    top: 92px;
  }
  .ticker-head {
    padding-bottom: 1rem;
    margin-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .ticker-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .ticker-title {
    font-size: 1.15rem;
    margin-top: 0.3rem;
  }
  .ticker-updated {
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-top: 0.35rem;
  }
  .ticker-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }
  .ticker-link {
    display: block;
    padding: 0.7rem 0.6rem;
    margin-inline: -0.6rem;
    border-radius: var(--radius-sm);
    color: inherit;
    transition: background 0.15s ease;
  }
  .ticker-link:hover {
    background: rgba(45, 212, 191, 0.06);
  }
  .ticker-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.3rem;
  }
  .ticker-id {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-bright);
  }
  .ticker-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sev {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.18rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
    border: 1px solid transparent;
  }
  .sev-exploited {
    background: rgba(248, 113, 113, 0.16);
    color: #fca5a5;
    border-color: rgba(248, 113, 113, 0.4);
  }
  .sev-critical {
    background: rgba(248, 113, 113, 0.12);
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.3);
  }
  .sev-high {
    background: rgba(251, 146, 60, 0.12);
    color: #fb923c;
    border-color: rgba(251, 146, 60, 0.3);
  }
  .sev-medium {
    background: rgba(250, 204, 21, 0.1);
    color: #facc15;
    border-color: rgba(250, 204, 21, 0.28);
  }
  .sev-low,
  .sev-unrated {
    background: rgba(148, 163, 184, 0.1);
    color: var(--text-muted);
    border-color: var(--border-bright);
  }
  .ticker-empty {
    color: var(--text-dim);
    font-size: 0.9rem;
  }
  .ticker-source {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-dim);
  }
</style>
